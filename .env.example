# Copy to .env and fill in. Loaded by python-dotenv in src/longvideoagent/config.py.

# ── LLM backends (only need the ones referenced in configs/models/llm.yaml) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=                  # uses OpenAI-compatible endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Local vLLM server (optional) ──
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# ── Video generation backends ──
GOOGLE_API_KEY=                    # Veo via Gemini API
OMNIWEAVING_ENDPOINT=              # http://host:port if you self-host
WAN_LOCAL_CHECKPOINT=              # /path/to/wan2.6 weights

# ── Cache / output locations (override configs/default.yaml at runtime) ──
LVA_CACHE_ROOT=./.cache
LVA_OUTPUT_ROOT=./outputs
