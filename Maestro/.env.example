# Maestro 环境变量 —— 最基础配置（configs/basic.yaml）。
# 只需要下面三个 key。复制成 .env 或直接 export。
#
#   纯语言大模型 → OpenAI     （configs: models.llm.name = openai）
#   多模态大模型 → Qwen 系列   （configs: models.mllm.name = qwen-vl）
#   视频生成     → WaveSpeed   （configs: models.video_gen.name = wavespeed）

OPENAI_API_KEY=
QWEN_API_KEY=
WAVESPEED_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# 以下都是“可选 / 备用”后端的 key，作用和上面三个重复，先全部注释掉。
# 想换 LLM 供应商时再取消注释对应行，并改 configs 里的 models.llm.name。
# ────────────────────────────────────────────────────────────────────────

# 备用纯语言大模型供应商（和 OPENAI_API_KEY 作用相同，二选一即可）：
# DEEPSEEK_API_KEY=          # models.llm.name = deepseek
# ANTHROPIC_API_KEY=         # models.llm.name = anthropic
# LLM_API_KEY=               # models.llm.name = vllm / openai-compat（自建服务）
# LLM_BASE_URL=              # 自建 OpenAI 兼容端点，如 http://localhost:8000/v1

# 进阶：真实物理验证（需要 GPU + torch，basic 配置不开）：
# COTRACKER_CKPT=            # 可选 CoTracker 本地权重（否则走 torch.hub）
# GROUNDINGDINO_MODEL=       # 可选 GroundingDINO HF 模型 id（默认 grounding-dino-tiny）

# 服务器（只有用 `maestro serve` 暴露 HTTP API 时才需要；run-once 不需要）：
# MAESTRO_HOST=0.0.0.0
# MAESTRO_PORT=8000
# MAESTRO_LOG_LEVEL=INFO
