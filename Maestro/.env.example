# Maestro environment variables (v0.4).
# Defaults run fully on mocks — NO keys needed (configs/default.yaml is all
# mock-*; `python -m maestro.cli smoke` works key-free). Fill a key only when
# you flip the matching models.* name in the config to a real backend.

# ── LLM (planning brain) — models/llm_backends.py ──
# Set ONE matching the models.llm.name you choose:
#   name: openai    → OPENAI_API_KEY
#   name: deepseek  → DEEPSEEK_API_KEY
#   name: qwen      → QWEN_API_KEY
#   name: anthropic → ANTHROPIC_API_KEY
#   name: vllm / openai-compat → LLM_API_KEY (often unused) + LLM_BASE_URL
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=
LLM_API_KEY=                  # generic fallback (vLLM / any OpenAI-compat host)
LLM_BASE_URL=                 # e.g. http://localhost:8000/v1 for a vLLM server

# ── VLM judge & critic (PhysicsCritic / SemanticCritic / Tournament) ──
# models/mllm_backends.py reuses the SAME keys above:
#   models.mllm.name: gpt-4o / openai-vlm → OPENAI_API_KEY
#   models.mllm.name: qwen-vl             → QWEN_API_KEY
# (no separate VLM key — a non-decodable clip yields no vlm verdict, key or not.)

# ── Video generation — models/video_gen_backends.py ──
# WaveSpeed is the REAL hosted backend (no local GPU): set models.video_gen.name
# = "wavespeed". OmniWeaving / Wan are local-weight skeletons (not wired).
# This ONE key also powers audio (foley + TTS, models.audio_gen.name=wavespeed)
# and the extra video capabilities flf2v (first-last-frame) + video editing.
WAVESPEED_API_KEY=
# OMNIWEAVING_WEIGHTS=        # local OmniWeaving checkpoint (skeleton backend)
# WAN_WEIGHTS=                # local Wan2.x checkpoint (skeleton backend)

# ── Track extractor — physics/track_extractor_backends.py ──
# CoTracker is the real backend (needs torch); checkpoint optional (else torch.hub).
# COTRACKER_CKPT=             # /data/ckpts/cotracker3.pth
# Entity-grounding detector (GroundingDINO) seeds CoTracker on the ACTUAL named
# entity. It is HF-hub-loaded — NO separate key. Optional model-id override:
# GROUNDINGDINO_MODEL=        # default IDEA-Research/grounding-dino-tiny

# ── Audio — models/audio_gen_backends.py ──
# foley (MMAudio-v2 video→audio) and tts (MiniMax speech-2.5) are REAL on the
# WAVESPEED_API_KEY above (set models.audio_gen.name=wavespeed). music is still
# a deterministic placeholder. Default config keeps AudioGenTool on the mock.

# ── Server ──
MAESTRO_HOST=0.0.0.0
MAESTRO_PORT=8000
MAESTRO_OUTPUT_ROOT=outputs
MAESTRO_LOG_LEVEL=INFO

# ── Sandbox / safety ──
# When set to 1, ActAgent refuses to call tools whose spec.side_effects=True
# (useful for CI smoke runs / untrusted plan executions).
MAESTRO_SANDBOX=0
