# Maestro environment variables.
# v0.1 runs fully on mocks — no keys needed.
# Fill these in v0.2+ when swapping mocks for real models or exposing the server.

# ── LLM (planning brains) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── MLLM / VLM judge & critic (PhysicsCritic / SemanticCritic / Tournament) ──
QWEN_API_KEY=

# ── Video generation backend (set whichever you build_video_gen will dispatch to) ──
# See src/maestro/models/video_gen_backends.py
OMNIWEAVING_WEIGHTS=     # local path to OmniWeaving checkpoint
WAN_WEIGHTS=             # local path to Wan2.x checkpoint
VEO_API_KEY=             # hosted API fallback (Veo / Sora)

# ── Audio generation (v0.3 — AudioGenTool real backend) ──
BARK_WEIGHTS=
MUSICGEN_WEIGHTS=

# ── Server ──
MAESTRO_HOST=0.0.0.0
MAESTRO_PORT=8000
MAESTRO_OUTPUT_ROOT=outputs
MAESTRO_LOG_LEVEL=INFO

# ── Sandbox / safety ──
# When set to 1, ActAgent refuses to call tools whose spec.side_effects=True
# (useful for CI smoke runs / untrusted plan executions).
MAESTRO_SANDBOX=0
